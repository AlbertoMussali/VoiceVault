# Local development environment variables
# Copy to .env for local use and adjust values as needed.

# App
NODE_ENV=development
APP_PORT=3000

# Data
TODOS_FILE=./todos.json

# Optional external services (development placeholders)
API_BASE_URL=https://api.example.com
API_TOKEN=replace-with-local-dev-token

# Production database defaults for `infra/docker-compose.prod.yml`
POSTGRES_USER=voicevault
POSTGRES_PASSWORD=voicevault
POSTGRES_DB=voicevault
DATABASE_URL=postgresql+psycopg://voicevault:voicevault@db:5432/voicevault
REDIS_URL=redis://redis:6379/0

# Blob storage path mounted into API/backup containers
STORAGE_LOCAL_ROOT=/var/lib/voicevault/storage

# Backup schedule (minutes between snapshots; default 1440 = daily)
BACKUP_INTERVAL_MINUTES=1440

# Summary runtime gate (Phase 7 retention control)
REQUIRE_ZERO_RETENTION=false
PROVIDER_ZERO_RETENTION_APPROVED=false

# Auth security hardening
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=strict
AUTH_REFRESH_COOKIE_NAME=vv_refresh_token
AUTH_CSRF_COOKIE_NAME=vv_csrf_token
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_SPECIAL=false
